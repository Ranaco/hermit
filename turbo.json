{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "LOG_LEVEL",
    "LOG_FORMAT",
    "DATABASE_URL",
    "API_PREFIX",
    "VAULT_REQUEST_TIMEOUT",
    "VAULT_KEY_NAME",
    "JWT_ACCESS_SECRET",
    "JWT_REFRESH_SECRET",
    "JWT_ACCESS_EXPIRY",
    "JWT_REFRESH_EXPIRY",
    "JWT_ISSUER",
    "JWT_AUDIENCE",
    "BCRYPT_ROUNDS",
    "MAX_LOGIN_ATTEMPTS",
    "LOCKOUT_DURATION",
    "SESSION_DURATION",
    "PASSWORD_MIN_LENGTH",
    "MFA_ISSUER",
    "TRUSTED_PROXIES",
    "RATE_LIMIT_WINDOW_MS",
    "RATE_LIMIT_MAX",
    "AUTH_RATE_LIMIT_WINDOW_MS",
    "AUTH_RATE_LIMIT_MAX",
    "CORS_ORIGIN",
    "FRONTEND_URL",
    "EMAIL_FROM",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASS",
    "SMTP_SECURE",
    "ENABLE_MFA",
    "ENABLE_REGISTRATION",
    "ENABLE_EMAIL_VERIFICATION",
    "ENABLE_SWAGGER",
    "ENABLE_AUDIT_LOG",
    "SHARE_DEFAULT_EXPIRY",
    "SHARE_MAX_EXPIRY",
    "SHARE_MAX_ATTEMPTS",
    "HERMIT_SERVER_URL"
  ],
  "tasks": {
    "build": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "build/**",
        ".vercel/**",
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "dependsOn": []
    },
    "lint": {
      "dependsOn": [
        "^build",
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^build",
        "^check-types"
      ]
    },
    "dev": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    }
  }
}
