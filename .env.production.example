# ============================================
# Hermit KMS - Production Environment
# ============================================
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to version control.

POSTGRES_USER=hermit
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=hermit

# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl

CORS_ORIGIN=https://hermit.ranax.co
PORT=5001
NODE_ENV=production

# Vault transport
VAULT_ENDPOINT=https://hcv:8200
VAULT_TRANSIT_MOUNT=transit
VAULT_REQUEST_TIMEOUT=5000
VAULT_KEY_NAME=hermit-master-key
VAULT_SKIP_VERIFY=false
VAULT_CACERT=/deploy/hermit/vault/tls/ca.pem
VAULT_TLS_DISABLE=false
VAULT_TLS_DISABLE_NUMERIC=0
VAULT_NODE_ID=node01
VAULT_API_ADDR=https://hcv:8200
VAULT_CLUSTER_ADDR=https://hcv:8201

# App auth for the API should use scoped AppRole credentials.
# Prefer wrapped SecretIDs that are minted during operator-controlled bootstrap/provisioning.
VAULT_APPROLE_ROLE_ID_READ=
VAULT_APPROLE_WRAPPED_SECRET_ID_READ=
VAULT_APPROLE_ROLE_ID_WRITE=
VAULT_APPROLE_WRAPPED_SECRET_ID_WRITE=
VAULT_DEPLOY_TOKEN_FILE=/deploy/hermit/vault/init/provisioning/deploy-token

# Auto-unseal is optional but recommended for production.
# Configure only if using a supported KMS-backed seal.
VAULT_AUTO_UNSEAL_TYPE=
VAULT_AWSKMS_REGION=
VAULT_AWSKMS_KMS_KEY_ID=
VAULT_AWSKMS_ENDPOINT=

# Backup encryption. This passphrase file should exist only on the host.
VAULT_SNAPSHOT_PASSPHRASE_FILE=/deploy/hermit/vault/backups/.snapshot-passphrase
# Optional: s3://bucket/prefix or rclone remote:path
VAULT_BACKUP_REMOTE_URI=

# Email (optional)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@hermit.ranax.co
